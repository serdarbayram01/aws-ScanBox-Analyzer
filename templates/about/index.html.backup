{% extends "base.html" %}

{% block title %}About — AWS ScanBox{% endblock %}
{% block page_title %}<span data-i18n="about_title">About</span>{% endblock %}
{% block page_subtitle %}<span data-i18n="about_subtitle">Project Information</span>{% endblock %}

{% block sidebar_sections %}
<div class="nav-section-label" data-i18n="nav_section_main">Main</div>
<a class="nav-item active" data-section="dashboard" href="/about">
  <span class="nav-icon">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
    </svg>
  </span>
  <span class="nav-label" data-i18n="nav_dashboard">Dashboard</span>
</a>
{% endblock %}

{% block content %}
<link rel="stylesheet" href="/static/about/css/about.css">

<!-- GIF Background -->
<div class="about-bg"></div>

<div class="page-body" style="padding:0;overflow-y:auto;height:calc(100vh - 64px)">
<div class="about-content">

  <!-- ═══ TOP: Logo + Developer ═══ -->
  <div class="about-top">

    <!-- Logo / App Card -->
    <div class="about-glass about-logo-card">
      <img src="/static/favicon.svg" alt="ScanBox" class="about-logo-img">
      <div>
        <div class="about-app-name">ScanBox</div>
        <div class="about-app-sub">AWS SB Analyzer</div>
      </div>
      <div class="about-app-desc">
        Multi-dimensional AWS cloud intelligence platform.<br>
        Scan, secure, analyze, and advise — all from a single dashboard.
      </div>
      <span class="about-version">v1.0.0</span>

      <div class="about-tech-stack" style="margin-top:18px;justify-content:center">
        <span class="about-tech-pill">Flask</span>
        <span class="about-tech-pill">boto3</span>
        <span class="about-tech-pill">Chart.js</span>
        <span class="about-tech-pill">JointJS</span>
        <span class="about-tech-pill">ELK.js</span>
        <span class="about-tech-pill">ReportLab</span>
        <span class="about-tech-pill">Python</span>
        <span class="about-tech-pill">Vanilla JS</span>
      </div>
    </div>

    <!-- Developer Card -->
    <div class="about-glass about-dev-card">
      <div>
        <div class="about-dev-name">Serdar Bayram</div>
        <div class="about-dev-role">Cloud Platform & DevOps Engineer</div>
        <div class="about-dev-location">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Istanbul, Turkey
        </div>
      </div>

      <div class="about-dev-bio">
        Cloud & DevOps Engineer focused on automation, scalability, and cloud infrastructure.
        18+ years of experience building highly scalable systems across multiple cloud platforms.
      </div>

      <!-- Stats -->
      <div class="about-stats">
        <div class="about-stat">
          <span class="about-stat-val">18+</span>
          <span class="about-stat-label">Years Exp.</span>
        </div>
        <div class="about-stat">
          <span class="about-stat-val">20+</span>
          <span class="about-stat-label">Projects</span>
        </div>
        <div class="about-stat">
          <span class="about-stat-val">7K+</span>
          <span class="about-stat-label">Followers</span>
        </div>
        <div class="about-stat">
          <span class="about-stat-val">500K+</span>
          <span class="about-stat-label">Blog Reads</span>
        </div>
      </div>

      <!-- Social Links -->
      <div class="about-socials">
        <a href="https://github.com/serdarbayram01" target="_blank" class="about-social-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a href="https://www.linkedin.com/in/serdar-bayram-694bb54b/" target="_blank" class="about-social-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a href="https://www.serdarbayram.net/" target="_blank" class="about-social-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          Blog
        </a>
        <a href="https://www.youtube.com/@serdarbayram7186" target="_blank" class="about-social-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          YouTube
        </a>
        <a href="mailto:serdarbayram01@gmail.com" class="about-social-link">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Email
        </a>
      </div>
    </div>

  </div><!-- /about-top -->

  <!-- ═══ MODULES ═══ -->
  <div class="about-glass" style="margin-bottom:24px">
    <div class="about-modules-title">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#00ff41" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      MODULES
    </div>
    <div class="about-modules-grid">

      <a href="/" class="about-module-card">
        <div class="about-module-icon" style="background:rgba(255,153,0,0.1);color:#ff9900">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="about-module-name">FinOps</div>
        <div class="about-module-desc">AWS cost analysis, budget tracking, savings optimization, and multi-profile spending comparison.</div>
      </a>

      <a href="/secops" class="about-module-card">
        <div class="about-module-icon" style="background:rgba(34,197,94,0.1);color:#22c55e">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="about-module-name">SecOps</div>
        <div class="about-module-desc">24-service security scanner with CIS, HIPAA, ISO27001, and WAFR compliance scoring.</div>
      </a>

      <a href="/mapinventory" class="about-module-card">
        <div class="about-module-icon" style="background:rgba(59,130,246,0.1);color:#3b82f6">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
        </div>
        <div class="about-module-name">Map Inventory</div>
        <div class="about-module-desc">150+ AWS service discovery, resource cataloging, tagging analysis, and full account inventory.</div>
      </a>

      <a href="/topology" class="about-module-card">
        <div class="about-module-icon" style="background:rgba(139,92,246,0.1);color:#8b5cf6">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="18" r="3"/><line x1="8.5" y1="7.5" x2="15.5" y2="16.5"/><line x1="15.5" y1="7.5" x2="8.5" y2="16.5"/></svg>
        </div>
        <div class="about-module-name">Topology</div>
        <div class="about-module-desc">Interactive VPC network architecture visualization with JointJS, ELK layout, and multi-format export.</div>
      </a>

      <a href="/advice" class="about-module-card">
        <div class="about-module-icon" style="background:rgba(239,68,68,0.1);color:#ef4444">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </div>
        <div class="about-module-name">Advice</div>
        <div class="about-module-desc">AWS Well-Architected Framework assessment across 6 pillars with bilingual advisory reports.</div>
      </a>

      <a href="/health" class="about-module-card">
        <div class="about-module-icon" style="background:rgba(6,182,212,0.1);color:#06b6d4">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <div class="about-module-name">Health</div>
        <div class="about-module-desc">Real-time AWS region latency, DNS health monitoring, and service outage status tracking.</div>
      </a>

    </div>
  </div>

  <!-- ═══ FOOTER ═══ -->
  <div class="about-footer">
    Built with ❤ by <a href="https://github.com/serdarbayram01" target="_blank">Serdar Bayram</a> — © 2026–Present AWS ScanBox Analyzer
  </div>

</div><!-- /about-content -->
</div><!-- /page-body -->
{% endblock %}
